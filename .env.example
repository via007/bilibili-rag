# =====================================================
# LLM 厂商配置 (通过 LLM_PROVIDER 切换)
# =====================================================
LLM_PROVIDER=minimax  # dashscope/baidu/tencent/volcengine/zhipu/minimax/openai

# 阿里云 DashScope (默认)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 百度千帆
BAIDU_API_KEY=your-baidu-api-key
BAIDU_BASE_URL=https://qianfan.baidubce.com/v2

# 腾讯混元
TENCENT_API_KEY=your-tencent-api-key
TENCENT_BASE_URL=https://hunyuan.cloud.tencent.com/v1

# 字节火山引擎
VOLCENGINE_API_KEY=your-volcengine-api-key
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 智谱 AI
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# MiniMax
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# OpenAI (或其他兼容 API)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Model Config (根据 LLM_PROVIDER 选择对应模型)
# MiniMax: abab6.5s-chat, abab6.5g-chat, abab6.5-chat, abab5.5s-chat
# DashScope: qwen3-max, qwen3-plus, qwen3, qwen-turbo
# Baidu: ernie-4.0-8k, ernie-3.5-8k
# Tencent: hunyuan-pro, hunyuan-standard, hunyuan-lite
# VolcEngine: doubao-pro-4k, doubao-lite-4k
# Zhipu: glm-4, glm-4-flash, glm-4-plus
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo
LLM_MODEL=abab6.5s-chat
EMBEDDING_MODEL=embo-1

# DashScope ASR
ASR_MODEL=paraformer-v2
ASR_TIMEOUT=600
ASR_MODEL_LOCAL=paraformer-realtime-v2
ASR_INPUT_FORMAT=pcm

# App Config
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/bilibili_rag.db

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./data/chroma_db
