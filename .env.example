# OpenAI Compatible API (Alibaba Cloud DashScope)
DASHSCOPE_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Model Config
LLM_MODEL=qwen3-max
EMBEDDING_MODEL=text-embedding-v4
EVAL_LLM_MODEL=gpt-4o-mini

# Agentic RAG
AGENTIC_RAG_TOP_K=5
AGENTIC_RAG_MAX_HOPS=3

# LangSmith (用于 LangChain / LangGraph 自动追踪，无需代码改动)
# 设置 LANGCHAIN_TRACING_V2=true 或 LANGSMITH_TRACING=true 并填入 API key 即可启用
LANGCHAIN_TRACING_V2=true
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=bilibili-rag
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# DashScope ASR
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
ASR_MODEL=paraformer-v2
ASR_TIMEOUT=600
ASR_MODEL_LOCAL=paraformer-realtime-v2
ASR_INPUT_FORMAT=pcm

# App Config
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/bilibili_rag.db

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./data/chroma_db

# 分块策略配置（增强规则分块）
CHUNK_TARGET_SIZE=750
CHUNK_MIN_SIZE=300
CHUNK_MAX_SIZE=900
CHUNK_OVERLAP=100

# Embedding 版本号（修改分块策略或 embedding 输入时需递增，用于追踪旧索引）
EMBEDDING_VERSION=v1
